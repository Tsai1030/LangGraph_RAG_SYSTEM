# ============================================================
# .env.example — 複製成 .env 並填入值
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# 詳細啟動步驟見根目錄 SETUP.md
# ============================================================

# ── OpenAI（必填）─────────────────────────────────────────
# 取得：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model 配置（"provider:model" 格式，由 app/core/llm.py factory 解析）
# 範例：
#   openai:gpt-5.4
#   google_genai:gemini-3.1-pro       (需 GOOGLE_API_KEY + uv add langchain-google-genai)
#   anthropic:claude-sonnet-4-6       (需 ANTHROPIC_API_KEY + uv add langchain-anthropic)
LLM_MODEL=openai:gpt-5.4
GRADER_MODEL=openai:gpt-5.4-mini
FORM_MODEL=openai:gpt-5.4
EMBEDDING_MODEL=text-embedding-3-small

# 其他 provider API keys（依需求填）
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ── 資料庫 ─────────────────────────────────────────────────
# Pick ONE backend; comment the other block out.
#
# Option A — SQLite (no server required). Fine for solo dev. On Windows
# with PM2 + multi-process, SQLite WAL has a known stale-FD issue that
# causes "API sees old version of DB after pm2 restart" — see db.md.
DATABASE_URL=sqlite+aiosqlite:///./app.db
SYNC_DATABASE_URL=sqlite:///./app.db
LANGGRAPH_DB_PATH=./langgraph.db
#
# Option B — PostgreSQL 13+ (recommended on Windows). Setup:
#   1. Install PG (EnterpriseDB installer on Windows native)
#   2. As superuser, run:
#        create user kb_user with password '<pwd>';
#        create database kb_app       owner kb_user;
#        create database kb_search    owner kb_user;
#        create database kb_langgraph owner kb_user;
#   3. uv add asyncpg psycopg2-binary langgraph-checkpoint-postgres
#   4. Comment out Option A above, uncomment Option B below, replace <pwd>
#   5. Run backend/scripts/migrate_sqlite_to_pg.py if you have existing
#      SQLite data to import (one-shot).
# DATABASE_URL=postgresql+asyncpg://kb_user:<pwd>@127.0.0.1:5432/kb_app
# SYNC_DATABASE_URL=postgresql+psycopg2://kb_user:<pwd>@127.0.0.1:5432/kb_app
# SEARCH_DATABASE_URL=postgresql+asyncpg://kb_user:<pwd>@127.0.0.1:5432/kb_search
# LANGGRAPH_DB_URL=postgresql://kb_user:<pwd>@127.0.0.1:5432/kb_langgraph

# ── JWT（必填）────────────────────────────────────────────
# 產生新 key（長度需 ≥ 32 bytes）：
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ChromaDB（向量庫）─────────────────────────────────────
# 此 repo 已 commit v5 snapshot，clone 完即可使用
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_VERSIONS_PATH=./chroma_versions
CHROMA_ACTIVE_VERSION=v5

# ── App ───────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# 第一個 admin 帳號 — 啟動時若此 email 已註冊但非 admin，自動升 admin
INITIAL_ADMIN_EMAIL=

# ── Google OAuth ──────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# 不需要 client secret（GIS ID-token flow 由前端傳 ID token、後端用 google-auth 驗簽）
GOOGLE_CLIENT_ID=
# 公司網域限制 — 只允許此網域的 Google 帳號登入/註冊；空字串 = 不限制
ALLOWED_EMAIL_DOMAIN=
# false = 禁止 email+密碼註冊（既有密碼帳號仍可登入；新人只能走 Google）
ALLOW_PASSWORD_REGISTER=false

# ── SMTP（可選；只有要寄密碼重設信時需要）──────────────
# Gmail 範例（需用 App Password，不是 Google 帳號密碼）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=

# ── LangSmith Tracing（可選；觀測 / debug 用）─────────────
# 取得：https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=LangGraph-RAG
