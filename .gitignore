# ============================================================
# 根目錄 .gitignore — 營造業知識 RAG 系統
# ============================================================

# ── 環境變數 ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python / Backend ──────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.pyo
.venv/
dist/
build/

# SQLite 資料庫
*.db
*.db-shm
*.db-wal

# ChromaDB 持久化資料
backend/chroma_db/
backend/chroma_dev_db/
backend/chroma_versions/

# DEV worktree 用的資料庫 / 不入 git
backend/app.dev.db
backend/app.dev.db-shm
backend/app.dev.db-wal
backend/langgraph.dev.db
backend/langgraph.dev.db-shm
backend/langgraph.dev.db-wal

# Alembic pycache
backend/alembic/__pycache__/

# 腳本輸出（chunks, hashes, review CSV…）
backend/scripts/output/

# ── Node.js / Frontend ────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# TypeScript build info
*.tsbuildinfo
frontend/next-env.d.ts

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# ── Claude Code 工作目錄 ──────────────────────────────────
.claude/
