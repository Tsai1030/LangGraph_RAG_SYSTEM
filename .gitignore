# ============================================================
# 根目錄 .gitignore — 營造業知識 RAG 系統
# ============================================================

# ── 環境變數 ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python / Backend ──────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.pyo
.venv/
dist/
build/

# SQLite 資料庫
*.db
*.db-shm
*.db-wal
# 備份 / snapshot 檔（如 app.db.backup-20260507-113555、app.db.pre-automation-*、
# app.db.snapshot-before-rollback-*、langgraph.db.backup-* 等）— 本機 rollback 用，不入 git
*.db.backup-*
*.db.pre-*
*.db.snapshot-*

# Token / 容量分析輸出
token*.csv
token_report.txt
form_structure.txt

# SEARCH 模組產生的 Word 檔（一次 run 一份；不入 git，跟 chroma_db 同性質）
backend/data/search_outputs/

# VLM 使用者上傳圖片（執行期資料；不入 git，跟 chroma_db / search_outputs 同性質）
backend/data/uploads/

# ChromaDB 持久化資料
backend/chroma_db/
backend/chroma_dev_db/
backend/chroma_versions/

# DEV worktree 用的資料庫 / 不入 git
backend/app.dev.db
backend/app.dev.db-shm
backend/app.dev.db-wal
backend/langgraph.dev.db
backend/langgraph.dev.db-shm
backend/langgraph.dev.db-wal

# Alembic pycache
backend/alembic/__pycache__/

# 腳本輸出（chunks, hashes, review CSV…）
backend/scripts/output/

# ── Node.js / Frontend ────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# TypeScript build info
*.tsbuildinfo
frontend/next-env.d.ts

# ── 機密 / 本機產物 ───────────────────────────────────────
# TLS 憑證與私鑰（Tailscale funnel 用）— 絕不入 git
certs/
# DB dump（pg_dump 產物，含使用者資料）
*.dump
# 根目錄雜散檔（redis-cli 殘留 / graph 視覺化輸出）
/query
graph_flow.png

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# ── Claude Code 工作目錄 ──────────────────────────────────
.claude/
