# ============================================================
# 根目錄 .gitignore — 營造業知識 RAG 系統
# ============================================================

# ── 環境變數 ──────────────────────────────────────────────
.env
.env.*

# ── Python / Backend ──────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.pyo
.venv/
dist/
build/

# SQLite 資料庫
*.db
*.db-shm
*.db-wal

# ChromaDB 持久化資料
backend/chroma_db/

# Alembic pycache
backend/alembic/__pycache__/

# 腳本輸出（chunks, hashes, review CSV…）
backend/scripts/output/

# ── Node.js / Frontend ────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# TypeScript build info
*.tsbuildinfo
frontend/next-env.d.ts

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# ── Claude Code 工作目錄 ──────────────────────────────────
.claude/
